[Unit]
Description=H2V2 Web (Vite Preview)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=h2v2
Group=h2v2
EnvironmentFile=/opt/h2v2/.env.generated
Environment=NODE_ENV=production
WorkingDirectory=/opt/h2v2/current/web
ExecStart=/usr/bin/npm run start -- --port ${PANEL_WEB_PORT}
Restart=always
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target

