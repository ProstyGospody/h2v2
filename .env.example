# H2V2 generated runtime environment example.
# During deployment values are written to /opt/h2v2/.env.generated by deploy/install.sh

APP_ENV=production
PANEL_API_LISTEN_ADDR=127.0.0.1:18080
PANEL_API_INTERNAL_URL=http://127.0.0.1:18080
PANEL_PUBLIC_HOST=panel.example.com
PANEL_PUBLIC_PORT=8443
PANEL_PUBLIC_URL=https://panel.example.com:8443
SUBSCRIPTION_PUBLIC_HOST=sub.panel.example.com
SUBSCRIPTION_PUBLIC_URL=https://sub.panel.example.com:8443
PANEL_STORAGE_DRIVER=file
PANEL_STORAGE_ROOT=/var/lib/h2v2
PANEL_SQLITE_PATH=/var/lib/h2v2/data/h2v2.db
PANEL_AUDIT_DIR=/var/log/h2v2/audit
PANEL_RUNTIME_DIR=/run/h2v2

SESSION_COOKIE_NAME=pp_session
CSRF_COOKIE_NAME=pp_csrf
CSRF_HEADER_NAME=X-CSRF-Token
VITE_API_PROXY_TARGET=http://127.0.0.1:18080
VITE_CSRF_COOKIE_NAME=pp_csrf
VITE_CSRF_HEADER_NAME=X-CSRF-Token
VITE_ALLOWED_HOSTS=*
SESSION_TTL=24h
SECURE_COOKIES=true

INTERNAL_AUTH_TOKEN=replace_with_random

HY2_DOMAIN=hy2.example.com
HY2_PORT=443
HY2_CONFIG_PATH=/etc/h2v2/hysteria/server.yaml
HY2_STATS_URL=http://127.0.0.1:8999
HY2_STATS_SECRET=replace_with_random
HY2_POLL_INTERVAL=20s

SERVICE_POLL_INTERVAL=60s
MANAGED_SERVICES=h2v2-api,h2v2-web,hysteria-server
SYSTEMCTL_PATH=/usr/bin/systemctl
SUDO_PATH=/usr/bin/sudo
JOURNALCTL_PATH=/usr/bin/journalctl
SERVICE_LOG_LINES_MAX=120

AUTH_RATE_LIMIT_WINDOW=15m
AUTH_RATE_LIMIT_BURST=10

HY2_BINARY_PATH=/usr/local/bin/hysteria
